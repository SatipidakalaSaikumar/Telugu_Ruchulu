            <ul id="cart-list" class="divide-y divide-gray-200">\
                <li class="py-2 text-gray-500">Your cart is empty</li>\
            </ul>\
            <div class="mt-4 flex justify-between items-center font-bold text-xl">\
                <span>Total:</span>\
                <span id="total-price">$0.00</span>\
            </div>\
            <button onclick="sendOrder()" class="w-full mt-6 bg-green-500 hover:bg-green-600 text-white font-bold py-3 rounded-lg transition">\
