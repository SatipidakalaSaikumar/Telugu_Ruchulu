    <meta name="viewport" content="width=device-width, initial-scale=1.0">\
    <title>Uncle's Catering Menu</title>\
    <script src="https://cdn.tailwindcss.com"></script>\
</head>\
<body class="bg-gray-50 font-sans">\
\
    <header class="bg-orange-500 text-white p-6 shadow-md text-center">\
        <h1 class="text-3xl font-bold">Uncle's Delicious Catering</h1>\
        <p class="mt-2">Select your items and send your order via WhatsApp</p>\
    </header>\
\
    <main class="max-w-4xl mx-auto p-4">\
